#!/usr/bin/env zsh

set -euo pipefail

TRITONS="$HOME/triton"
REPO_NAME="triton"
SCRIPTS_ROOT="${0:a:h:h}"

source "${SCRIPTS_ROOT}/utils/worktree-functions.sh"

MAIN_TRITON="$(find_main_repository "$TRITONS" "$REPO_NAME")"
TRITONS="${MAIN_TRITON:h:h}"

if [[ ! -d $MAIN_TRITON ]]; then
    echo "No main Triton repository in the expected place"
    exit 1
fi

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <branch or path>"
    echo ""
    echo "Remove the worktree for the named branch (or if no such branch"
    echo "at the given path), getting rid of the build environment."
    exit 1
fi

declare BRANCH_OR_PATH=$1
declare WORKTREE_PATH
if ! WORKTREE_PATH=$(find_worktree_path "$MAIN_TRITON" "$TRITONS" "$REPO_NAME" "$BRANCH_OR_PATH"); then
    echo "Could not find worktree for branch/path: $BRANCH_OR_PATH"
    exit 1
fi

if [[ ! -d "$WORKTREE_PATH" ]]; then
    echo "Somehow, $WORKTREE_PATH doesn't exist. Can't happen."
    exit 2
fi

WORKTREE_ENV="${WORKTREE_PATH:h}"

cd "$MAIN_TRITON"
echo "Removing worktree $WORKTREE_PATH ..."
git worktree remove "$WORKTREE_PATH"

cleanup_worktree_env "$WORKTREE_ENV" "$BRANCH_OR_PATH" "$SCRIPTS_ROOT/config/triton-workspace-seed"
