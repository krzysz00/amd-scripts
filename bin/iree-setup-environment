#!/usr/bin/env zsh

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 [root directory]"
  exit 1
fi

root_dir="$1"
if [[ ! -d "$root_dir/iree/compiler" ]]; then
  echo "Error: expected $root_dir to heuristically be an IREE checkout"
  exit 1
fi

pushd "$root_dir"
if [[ ! -e "$root_dir/.envrc" ]]; then
  echo "use iree $root_dir $root_dir/build python3 $root_dir/iree" >.envrc
  direnv allow .
fi
eval "$(direnv export zsh)"
echo "Installing Python dependencies..."
uv pip install -q -r "$root_dir/iree/runtime/bindings/python/iree/runtime/build_requirements.txt"
uv pip install -q nanobind pre-commit

if [[ ! -e "$root_dir/compile_commands.json" ]]; then
  ln -s "$root_dir/build/compile_commands.json" "compile_commands.json"
fi
if [[ ! -e "$root_dir/tablegen_compile_commands.yml" ]]; then
  ln -s "$root_dir/build/tablegen_compile_commands.yml" "tablegen_compile_commands.yml"
fi

echo "Set up IREE build envoronment in $root_dir"

popd
