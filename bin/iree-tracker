#!/usr/bin/env python3
# WARNING: AI-generated, one-off personal helper. Not intended for wide use
# or sharing within the team — file an issue against the author, not the
# script, if it misbehaves.
#
# CLI front-end for the GitHub Projects v2 board at
# https://github.com/orgs/nod-ai/projects/40 ("Codegen Tracker").
# Issues live on iree-org/iree or nod-ai/amd-shark-ai; this script wraps the
# everyday "create / import / list / poke" flows in `dialog` prompts, with
# CLI flags for every prompt so it can also run non-interactively.
#
# Requires: `gh` (with `project` + `read:project` scopes — run
#   `gh auth refresh -s project,read:project` once), and `dialog`.

import argparse
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Callable, Iterable, Optional
from urllib.parse import urlparse


# ── Configuration ────────────────────────────────────────────────────────────

ORG = "nod-ai"
PROJECT_NUM = 40
ISSUE_REPOS = {"iree": "iree-org/iree"}
# Sentinel returned by _resolve_repo when the user picks "create as a draft on
# the project board" instead of filing a real issue. Drafts live on the project
# itself, so any project collaborator can create/assign them — no repo perms
# needed.
DRAFT_TARGET = "__draft__"
DEFAULT_USER = "krzysz00"
CACHE_PATH = (
    Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache")))
    / "iree-tracker"
    / f"project-{PROJECT_NUM}.json"
)
NO_STATUS = "(no status)"


# ── gh / GraphQL helpers ─────────────────────────────────────────────────────


class GhError(RuntimeError):
    pass


def run_gh(args: list[str], *, input_text: Optional[str] = None) -> str:
    """Run `gh` with the given args, return stdout. Raises GhError on failure."""
    proc = subprocess.run(
        ["gh", *args],
        input=input_text,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        raise GhError(
            f"gh {' '.join(shlex.quote(a) for a in args)} failed "
            f"(exit {proc.returncode}): {proc.stderr.strip()}"
        )
    return proc.stdout


def gh_graphql(query: str, **variables) -> dict:
    """Run a GraphQL query/mutation through `gh api graphql`. Returns `data`."""
    args = ["api", "graphql", "-f", f"query={query}"]
    for k, v in variables.items():
        if isinstance(v, bool):
            args += ["-F", f"{k}={'true' if v else 'false'}"]
        elif isinstance(v, int):
            args += ["-F", f"{k}={v}"]
        elif v is None:
            continue
        elif isinstance(v, list):
            # gh's `key[]=value` syntax builds a JSON array. Skipping when empty
            # leaves the variable null, which matches the GraphQL default.
            for item in v:
                args += ["-f", f"{k}[]={item}"]
        else:
            args += ["-f", f"{k}={v}"]
    try:
        out = run_gh(args)
    except GhError as e:
        msg = str(e)
        if "INSUFFICIENT_SCOPES" in msg or "read:project" in msg:
            sys.exit(
                "Your `gh` token lacks the project scopes. Run:\n\n"
                "  gh auth refresh -s project,read:project\n\n"
                "and try again."
            )
        raise
    payload = json.loads(out)
    if "errors" in payload:
        raise GhError(f"GraphQL errors: {json.dumps(payload['errors'], indent=2)}")
    return payload["data"]


# ── Project metadata (cached) ────────────────────────────────────────────────


@dataclass
class FieldMeta:
    id: str
    name: str
    data_type: str
    options: list[tuple[str, str]] = field(default_factory=list)  # [(name, id)]

    def option_id(self, name: str) -> str:
        for n, oid in self.options:
            if n == name:
                return oid
        raise KeyError(
            f"No option named {name!r} on field {self.name!r}. "
            f"Available: {[n for n, _ in self.options]}"
        )

    def option_names(self) -> list[str]:
        return [n for n, _ in self.options]


@dataclass
class ProjectMeta:
    id: str
    title: str
    url: str
    fields: dict[str, FieldMeta]  # by field name

    def field(self, name: str) -> FieldMeta:
        if name not in self.fields:
            raise KeyError(
                f"Project has no field named {name!r}. Known fields: "
                f"{sorted(self.fields)}"
            )
        return self.fields[name]


_PROJECT_META_QUERY = """
query($org: String!, $num: Int!) {
  organization(login: $org) {
    projectV2(number: $num) {
      id title url
      fields(first: 50) {
        nodes {
          __typename
          ... on ProjectV2FieldCommon { id name dataType }
          ... on ProjectV2SingleSelectField {
            id name dataType
            options { id name }
          }
        }
      }
    }
  }
}
"""


def _query_project_meta(org: str, num: int) -> ProjectMeta:
    data = gh_graphql(_PROJECT_META_QUERY, org=org, num=num)
    proj = data["organization"]["projectV2"]
    if proj is None:
        raise GhError(f"No project number {num} on org {org}")
    fields: dict[str, FieldMeta] = {}
    for node in proj["fields"]["nodes"]:
        opts = [(o["name"], o["id"]) for o in (node.get("options") or [])]
        fields[node["name"]] = FieldMeta(
            id=node["id"],
            name=node["name"],
            data_type=node["dataType"],
            options=opts,
        )
    return ProjectMeta(id=proj["id"], title=proj["title"], url=proj["url"], fields=fields)


def load_project_meta(refresh: bool = False) -> ProjectMeta:
    if not refresh and CACHE_PATH.exists():
        try:
            raw = json.loads(CACHE_PATH.read_text())
            fields = {
                name: FieldMeta(
                    id=f["id"],
                    name=name,
                    data_type=f["data_type"],
                    options=[(n, i) for n, i in f["options"]],
                )
                for name, f in raw["fields"].items()
            }
            return ProjectMeta(id=raw["id"], title=raw["title"], url=raw["url"], fields=fields)
        except (json.JSONDecodeError, KeyError, TypeError):
            pass  # fall through to refetch

    meta = _query_project_meta(ORG, PROJECT_NUM)
    CACHE_PATH.parent.mkdir(parents=True, exist_ok=True)
    CACHE_PATH.write_text(
        json.dumps(
            {
                "id": meta.id,
                "title": meta.title,
                "url": meta.url,
                "fields": {
                    name: {
                        "id": f.id,
                        "data_type": f.data_type,
                        "options": [list(o) for o in f.options],
                    }
                    for name, f in meta.fields.items()
                },
            },
            indent=2,
        )
    )
    return meta


# ── dialog wrappers ──────────────────────────────────────────────────────────


def _dialog(args: list[str]) -> tuple[int, str]:
    if shutil.which("dialog") is None:
        sys.exit("`dialog` not installed. Install via your package manager.")
    proc = subprocess.run(
        ["dialog", "--stdout", *args],
        stdin=sys.stdin,
        stdout=subprocess.PIPE,
        stderr=sys.stderr,
        text=True,
    )
    return proc.returncode, proc.stdout.rstrip("\n")


def dialog_menu(title: str, prompt: str, choices: list[tuple[str, str]]) -> Optional[str]:
    """Returns the chosen tag, or None if cancelled."""
    args = ["--title", title, "--menu", prompt, "20", "80", str(min(15, len(choices)))]
    for tag, desc in choices:
        args += [tag, desc]
    code, out = _dialog(args)
    return out if code == 0 else None


def dialog_checklist(
    title: str,
    prompt: str,
    choices: list[tuple[str, str, bool]],
    no_tags: bool = False,
) -> Optional[list[str]]:
    """Returns list of chosen tags, or None if cancelled.

    `no_tags=True` hides the tag column (useful when the tag is an opaque ID
    like a project item node id and only the description is meaningful).
    """
    args = ["--title", title]
    if no_tags:
        args.append("--no-tags")
    args += ["--separate-output", "--checklist", prompt, "-1", "-1", "-1"]
    for tag, desc, on in choices:
        args += [tag, desc, "on" if on else "off"]
    code, out = _dialog(args)
    if code != 0:
        return None
    return [line for line in out.split("\n") if line]


def dialog_inputbox(title: str, prompt: str, default: str = "") -> Optional[str]:
    code, out = _dialog(["--title", title, "--inputbox", prompt, "10", "70", default])
    return out if code == 0 else None


def dialog_yesno(title: str, prompt: str) -> bool:
    proc = subprocess.run(
        ["dialog", "--title", title, "--yesno", prompt, "10", "70"],
        stdin=sys.stdin, stdout=sys.stderr, stderr=sys.stderr,
    )
    return proc.returncode == 0


# ── Project mutations ────────────────────────────────────────────────────────


def add_draft_issue(
    project_id: str, title: str, body: str, assignee_ids: list[str]
) -> str:
    data = gh_graphql(
        """
        mutation($p: ID!, $t: String!, $b: String!, $a: [ID!]) {
          addProjectV2DraftIssue(input: {
            projectId: $p, title: $t, body: $b, assigneeIds: $a
          }) {
            projectItem { id }
          }
        }
        """,
        p=project_id, t=title, b=body, a=assignee_ids,
    )
    return data["addProjectV2DraftIssue"]["projectItem"]["id"]


def fetch_user_node_id(login: str) -> str:
    return run_gh(["api", f"users/{login}", "--jq", ".node_id"]).strip()


def add_issue_to_project(project_id: str, content_node_id: str) -> str:
    data = gh_graphql(
        """
        mutation($project: ID!, $content: ID!) {
          addProjectV2ItemById(input: {projectId: $project, contentId: $content}) {
            item { id }
          }
        }
        """,
        project=project_id,
        content=content_node_id,
    )
    return data["addProjectV2ItemById"]["item"]["id"]


def set_single_select(project_id: str, item_id: str, field_meta: FieldMeta, option_name: str) -> None:
    option_id = field_meta.option_id(option_name)
    gh_graphql(
        """
        mutation($p: ID!, $i: ID!, $f: ID!, $o: String!) {
          updateProjectV2ItemFieldValue(input: {
            projectId: $p, itemId: $i, fieldId: $f,
            value: {singleSelectOptionId: $o}
          }) { projectV2Item { id } }
        }
        """,
        p=project_id, i=item_id, f=field_meta.id, o=option_id,
    )


def clear_field(project_id: str, item_id: str, field_meta: FieldMeta) -> None:
    gh_graphql(
        """
        mutation($p: ID!, $i: ID!, $f: ID!) {
          clearProjectV2ItemFieldValue(input: {
            projectId: $p, itemId: $i, fieldId: $f
          }) { projectV2Item { id } }
        }
        """,
        p=project_id, i=item_id, f=field_meta.id,
    )


# ── Project queries ──────────────────────────────────────────────────────────


_ITEMS_QUERY = """
query($org: String!, $num: Int!, $cursor: String) {
  organization(login: $org) {
    projectV2(number: $num) {
      items(first: 100, after: $cursor) {
        pageInfo { hasNextPage endCursor }
        nodes {
          id
          content {
            __typename
            ... on Issue {
              id number title url state createdAt
              repository { nameWithOwner }
              author { login }
              assignees(first: 10) { nodes { login } }
            }
            ... on PullRequest {
              id number title url state createdAt
              repository { nameWithOwner }
              author { login }
              assignees(first: 10) { nodes { login } }
            }
            ... on DraftIssue {
              id title createdAt
              creator { login }
              assignees(first: 10) { nodes { login } }
            }
          }
          fieldValues(first: 30) {
            nodes {
              __typename
              ... on ProjectV2ItemFieldSingleSelectValue {
                field { ... on ProjectV2FieldCommon { name } }
                name
              }
              ... on ProjectV2ItemFieldTextValue {
                field { ... on ProjectV2FieldCommon { name } }
                text
              }
              ... on ProjectV2ItemFieldDateValue {
                field { ... on ProjectV2FieldCommon { name } }
                date
              }
            }
          }
        }
      }
    }
  }
}
"""


def fetch_project_items() -> list[dict]:
    """Fetch all items as a list of normalized dicts."""
    items: list[dict] = []
    cursor: Optional[str] = None
    while True:
        data = gh_graphql(_ITEMS_QUERY, org=ORG, num=PROJECT_NUM, cursor=cursor)
        page = data["organization"]["projectV2"]["items"]
        for node in page["nodes"]:
            items.append(_normalize_item(node))
        if not page["pageInfo"]["hasNextPage"]:
            break
        cursor = page["pageInfo"]["endCursor"]
    return items


def _normalize_item(node: dict) -> dict:
    content = node.get("content") or {}
    typ = content.get("__typename", "Unknown")
    author_login = None
    if typ in ("Issue", "PullRequest"):
        author_login = (content.get("author") or {}).get("login")
    elif typ == "DraftIssue":
        author_login = (content.get("creator") or {}).get("login")
    assignees = [a["login"] for a in (content.get("assignees", {}) or {}).get("nodes", [])]
    fvs: dict[str, str] = {}
    for fv in node.get("fieldValues", {}).get("nodes", []):
        f = fv.get("field") or {}
        name = f.get("name")
        if not name:
            continue
        if "name" in fv:
            fvs[name] = fv["name"]
        elif "text" in fv:
            fvs[name] = fv["text"]
        elif "date" in fv:
            fvs[name] = fv["date"]
    return {
        "item_id": node["id"],
        "type": typ,
        "content_id": content.get("id"),
        "number": content.get("number"),
        "title": content.get("title", "(untitled)"),
        "url": content.get("url"),
        "state": content.get("state"),
        "created_at": content.get("createdAt"),
        "repo": (content.get("repository") or {}).get("nameWithOwner"),
        "author": author_login,
        "assignees": assignees,
        "fields": fvs,
    }


# ── Issue helpers (REST + gh issue) ──────────────────────────────────────────


_URL_RE = re.compile(
    r"^https?://github\.com/(?P<owner>[^/]+)/(?P<repo>[^/]+)/(?:issues|pull)/(?P<num>\d+)/?$"
)


def parse_issue_url(url: str) -> tuple[str, str, int]:
    m = _URL_RE.match(url.strip())
    if not m:
        raise ValueError(
            f"Not a recognized GitHub issue/PR URL: {url!r}\n"
            "Expected https://github.com/<owner>/<repo>/issues/<n>"
        )
    return m.group("owner"), m.group("repo"), int(m.group("num"))


def fetch_issue_node_id(owner: str, repo: str, number: int) -> str:
    out = run_gh(
        ["api", f"repos/{owner}/{repo}/issues/{number}", "--jq", ".node_id"]
    )
    nid = out.strip()
    if not nid:
        raise GhError(f"No node_id returned for {owner}/{repo}#{number}")
    return nid


def fetch_repo_labels(repo: str) -> list[tuple[str, str]]:
    out = run_gh(["label", "list", "-R", repo, "--json", "name,description", "--limit", "200"])
    items = json.loads(out)
    return [(it["name"], (it.get("description") or "").strip()) for it in items]


# ── Editor ───────────────────────────────────────────────────────────────────


def edit_with_editor(seed_title: Optional[str]) -> tuple[str, str]:
    """Open $EDITOR on a seeded markdown file. Return (title, body)."""
    seed = f"# {seed_title}\n\n" if seed_title else "# \n\n"
    with tempfile.NamedTemporaryFile(
        mode="w+", suffix=".md", delete=False, prefix="iree-tracker-"
    ) as tf:
        tf.write(seed)
        path = tf.name
    try:
        editor = os.environ.get("EDITOR", "nano")
        rc = subprocess.call([editor, path])
        if rc != 0:
            raise RuntimeError(f"Editor exited with status {rc}")
        text = Path(path).read_text()
    finally:
        os.unlink(path)
    return _split_title_body(text)


def _split_title_body(text: str) -> tuple[str, str]:
    lines = text.splitlines()
    title = ""
    rest_start = 0
    for idx, line in enumerate(lines):
        s = line.strip()
        if not s:
            continue
        title = s.lstrip("#").strip()
        rest_start = idx + 1
        break
    body = "\n".join(lines[rest_start:]).lstrip("\n")
    return title, body


# ── Sub-command: create ──────────────────────────────────────────────────────


def cmd_create(args, meta: ProjectMeta) -> int:
    # 1. Title + body.
    title = args.title
    body = args.body
    if args.body_file is not None:
        body = Path(args.body_file).read_text()
    if body is None and not args.no_editor:
        ed_title, ed_body = edit_with_editor(title)
        if not ed_title:
            sys.exit("No title found in the editor file (first non-empty line is taken).")
        title = ed_title
        body = ed_body
    elif body is None and args.no_editor:
        body = ""

    if not title:
        sys.exit("--title is required when skipping the editor.")

    # 2. Repo (or draft).
    repo = _resolve_repo(args.repo)
    if repo is None:
        sys.exit("Cancelled.")
    is_draft = repo == DRAFT_TARGET

    # 3. Labels (drafts can't have them).
    if is_draft:
        if args.label:
            sys.exit("--label is not supported for draft issues.")
        labels: list[str] = []
    else:
        picked = _resolve_labels(args.label, repo)
        if picked is None:
            sys.exit("Cancelled.")
        labels = picked

    # 4-6. Project field values.
    category = _resolve_optional_single_select(meta, "Category", args.category)
    if category is None and args.category is None:
        sys.exit("Cancelled.")
    priority = _resolve_optional_single_select(meta, "Priority", args.priority)
    if priority is None and args.priority is None:
        sys.exit("Cancelled.")
    project_field = _resolve_optional_single_select(meta, "Project", args.project_field)
    if project_field is None and args.project_field is None:
        sys.exit("Cancelled.")

    assignee = _resolve_assignee(args.assignee)
    if assignee is None and args.assignee is None:
        sys.exit("Cancelled.")
    # Empty string assignee means "no assignee".

    status = _resolve_status(meta, args.status)

    # Final confirm.
    if not args.yes:
        summary = (
            f"Title:    {title}\n"
            f"Repo:     {'(draft)' if is_draft else repo}\n"
            f"Labels:   {', '.join(labels) if labels else '(none)'}\n"
            f"Category: {category or '(none)'}\n"
            f"Priority: {priority or '(none)'}\n"
            f"Project:  {project_field or '(none)'}\n"
            f"Assignee: {assignee or '(none)'}\n"
            f"Status:   {status or '(none)'}\n"
        )
        if not dialog_yesno("Create issue?", summary):
            sys.exit("Cancelled.")

    # 7. Create the issue (or draft) and get the project item id.
    if is_draft:
        assignee_ids = [fetch_user_node_id(assignee)] if assignee else []
        item_id = add_draft_issue(meta.id, title, body or "", assignee_ids)
        print(f"Created draft on project: {meta.url}")
    else:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False, prefix="iree-tracker-body-") as tf:
            tf.write(body or "")
            body_path = tf.name
        try:
            gh_args = ["issue", "create", "-R", repo, "--title", title, "--body-file", body_path]
            for label in labels:
                gh_args += ["--label", label]
            if assignee:
                gh_args += ["--assignee", assignee]
            url = run_gh(gh_args).strip().splitlines()[-1]
        finally:
            os.unlink(body_path)
        print(f"Created issue: {url}")
        owner, name, number = parse_issue_url(url)
        node_id = fetch_issue_node_id(owner, name, number)
        item_id = add_issue_to_project(meta.id, node_id)

    # 8. Set project fields.
    if status:
        set_single_select(meta.id, item_id, meta.field("Status"), status)
    if category:
        set_single_select(meta.id, item_id, meta.field("Category"), category)
    if priority:
        set_single_select(meta.id, item_id, meta.field("Priority"), priority)
    if project_field:
        set_single_select(meta.id, item_id, meta.field("Project"), project_field)
    if not is_draft:
        print(f"Added to project: {meta.url}")
    return 0


def _resolve_repo(arg: Optional[str]) -> Optional[str]:
    """Returns full "owner/name", DRAFT_TARGET, or None if cancelled."""
    if arg is not None:
        if arg == "draft":
            return DRAFT_TARGET
        return ISSUE_REPOS.get(arg, arg)
    choices = [(short, full) for short, full in ISSUE_REPOS.items()]
    choices.append(("draft", "(draft issue on the project board)"))
    pick = dialog_menu("Repository", "Where should the issue live?", choices)
    if pick is None:
        return None
    if pick == "draft":
        return DRAFT_TARGET
    return ISSUE_REPOS.get(pick)


def _resolve_labels(arg: Optional[list[str]], repo: str) -> Optional[list[str]]:
    if arg is not None:
        return [l for l in arg if l]
    labels = fetch_repo_labels(repo)
    if not labels:
        return []
    labels = sorted(labels, key=lambda x: x[0].lower())
    choices = [(name, desc or name, False) for name, desc in labels]
    picks = dialog_checklist("Labels", f"Labels for {repo}", choices)
    return picks


def _resolve_optional_single_select(
    meta: ProjectMeta, field_name: str, arg: Optional[str]
) -> Optional[str]:
    """Returns option name, "" to skip, or None if dialog cancelled.

    `arg` of "" or "na" means "leave unset".
    """
    f = meta.field(field_name)
    names = f.option_names()
    if arg is not None:
        if arg == "" or arg == "na":
            return ""
        if arg not in names:
            sys.exit(f"Unknown {field_name} {arg!r}; pick from {names + ['na']}")
        return arg
    choices = [("__skip", "(leave unset)")] + [(n, n) for n in names]
    pick = dialog_menu(field_name, f"Optional: {field_name}", choices)
    if pick is None:
        return None
    return "" if pick == "__skip" else pick


def _resolve_status(meta: ProjectMeta, arg: Optional[str]) -> str:
    """Returns status option name, or "" to leave unset. Defaults to "Todo"."""
    if arg is None:
        return "Todo"
    if arg == "" or arg == "na":
        return ""
    names = meta.field("Status").option_names()
    if arg not in names:
        sys.exit(f"Unknown status {arg!r}; pick from {names + ['na']}")
    return arg


def _resolve_assignee(arg: Optional[str]) -> Optional[str]:
    """Returns github handle, "" for unassigned, or None if cancelled."""
    if arg is not None:
        if arg == "none":
            return ""
        if arg == "me":
            return DEFAULT_USER
        return arg
    pick = dialog_menu(
        "Assignee", "Assign this issue to:",
        [("me", DEFAULT_USER), ("other", "Someone else…"), ("none", "Unassigned")],
    )
    if pick is None:
        return None
    if pick == "me":
        return DEFAULT_USER
    if pick == "none":
        return ""
    handle = dialog_inputbox("Assignee", "GitHub handle:")
    return handle or None  # cancellation in inputbox bubbles up


# ── Sub-command: import ──────────────────────────────────────────────────────


def cmd_import(args, meta: ProjectMeta) -> int:
    owner, repo, number = parse_issue_url(args.url)
    info = json.loads(
        run_gh(
            [
                "api", f"repos/{owner}/{repo}/issues/{number}",
                "--jq", "{node_id, title, html_url}",
            ]
        )
    )
    node_id = info["node_id"]
    print(f"Importing: {info['title']}\n  {info['html_url']}")

    category = _resolve_optional_single_select(meta, "Category", args.category)
    if category is None and args.category is None:
        sys.exit("Cancelled.")
    priority = _resolve_optional_single_select(meta, "Priority", args.priority)
    if priority is None and args.priority is None:
        sys.exit("Cancelled.")
    project_field = _resolve_optional_single_select(meta, "Project", args.project_field)
    if project_field is None and args.project_field is None:
        sys.exit("Cancelled.")

    status = _resolve_status(meta, args.status)

    if args.takeover is None:
        takeover = dialog_yesno(
            "Take over?",
            f"Assign {info['title']!r} to {DEFAULT_USER}?",
        )
    else:
        takeover = args.takeover

    if not args.yes:
        summary = (
            f"Adding to {meta.title}:\n  {info['title']}\n  {info['html_url']}\n\n"
            f"Status:   {status or '(none)'}\n"
            f"Category: {category or '(none)'}\n"
            f"Priority: {priority or '(none)'}\n"
            f"Project:  {project_field or '(none)'}\n"
            f"Takeover: {'yes' if takeover else 'no'}\n"
        )
        if not dialog_yesno("Import?", summary):
            sys.exit("Cancelled.")

    item_id = add_issue_to_project(meta.id, node_id)
    if status:
        set_single_select(meta.id, item_id, meta.field("Status"), status)
    if category:
        set_single_select(meta.id, item_id, meta.field("Category"), category)
    if priority:
        set_single_select(meta.id, item_id, meta.field("Priority"), priority)
    if project_field:
        set_single_select(meta.id, item_id, meta.field("Project"), project_field)

    if takeover:
        try:
            run_gh([
                "issue", "edit", str(number), "-R", f"{owner}/{repo}",
                "--add-assignee", DEFAULT_USER,
            ])
            print(f"Assigned to {DEFAULT_USER}")
        except GhError as e:
            print(
                f"Warning: couldn't assign to {DEFAULT_USER}: {e}",
                file=sys.stderr,
            )

    print(f"Added to project: {meta.url}")
    return 0


# ── Sub-commands: created / assigned ─────────────────────────────────────────


def _status_rank(status: Optional[str]) -> int:
    order = {"Todo": 0, NO_STATUS: 0, "In Progress": 1, "Done": 2}
    return order.get(status or NO_STATUS, 3)


def _priority_rank(priority: Optional[str], priority_order: list[str]) -> int:
    if priority is None:
        return len(priority_order)
    try:
        return priority_order.index(priority)
    except ValueError:
        return len(priority_order)


def _list_items(args, meta: ProjectMeta, predicate: Callable[[dict], bool], heading_name: str) -> int:
    all_items = fetch_project_items()
    matched = [it for it in all_items if predicate(it)]

    status_filter = set(args.status) if args.status else None
    if status_filter is None and not args.all_status:
        status_filter = {"Todo", "In Progress", NO_STATUS}
    if status_filter:
        matched = [
            it for it in matched
            if (it["fields"].get("Status") or NO_STATUS) in status_filter
        ]

    priority_order = meta.field("Priority").option_names()

    def sort_key(it: dict):
        status = it["fields"].get("Status") or NO_STATUS
        prio = it["fields"].get("Priority")
        # Include the status label so Todo/(no status) within the same rank
        # don't interleave and flip-flop the headings.
        return (_status_rank(status), status, _priority_rank(prio, priority_order),
                it.get("created_at") or "")

    matched.sort(key=sort_key)

    if args.format == "json":
        print(json.dumps(matched, indent=2))
        return 0

    if not matched:
        print(f"No items {heading_name} {args.user}.")
        return 0

    current_status: Optional[str] = None
    for it in matched:
        status = it["fields"].get("Status") or NO_STATUS
        if status != current_status:
            print(f"\n## {status}")
            current_status = status
        prio = it["fields"].get("Priority") or "-"
        cat = it["fields"].get("Category") or "-"
        proj = it["fields"].get("Project")
        proj_str = f" / {proj}" if proj else ""
        loc = f"{it['repo']}#{it['number']}" if it.get("repo") and it.get("number") else "(draft)"
        url = it.get("url") or ""
        print(f"- [{prio}] [{cat}{proj_str}] {loc} — {it['title']}" + (f" — {url}" if url else ""))
    return 0


def cmd_created(args, meta: ProjectMeta) -> int:
    user = args.user
    return _list_items(args, meta, lambda it: it.get("author") == user, f"created by")


def cmd_assigned(args, meta: ProjectMeta) -> int:
    user = args.user
    return _list_items(args, meta, lambda it: user in (it.get("assignees") or []), f"assigned to")


# ── Sub-command: poke ────────────────────────────────────────────────────────


def _days_old(created_at: Optional[str]) -> str:
    if not created_at:
        return "?d"
    try:
        dt = datetime.fromisoformat(created_at.replace("Z", "+00:00"))
    except ValueError:
        return "?d"
    delta = datetime.now(timezone.utc) - dt
    return f"{delta.days}d"


def _terminal_columns() -> int:
    """Actual column count of the controlling terminal. Goes through /dev/tty
    so it works even when stdout/stderr are piped."""
    try:
        with open("/dev/tty") as tty:
            return os.get_terminal_size(tty.fileno()).columns
    except OSError:
        return shutil.get_terminal_size((100, 30)).columns


def _ellipsize(s: str, max_len: int) -> str:
    if max_len <= 0 or not s:
        return ""
    if len(s) <= max_len:
        return s
    if max_len == 1:
        return s[:1]
    return s[: max_len - 1] + "…"


_PRIORITY_SHORT = {"Backlog": "B", "Tracking issues": "T"}


def _fit_poke_desc(
    title: str, loc: str, prio: str, age: str, max_width: int,
) -> str:
    """Assemble the poke description, trimming Title to fit `max_width`. If
    even the fixed parts (loc/prio/age) overflow, hard-truncate."""
    prio = _PRIORITY_SHORT.get(prio, prio)

    def assemble(t: str) -> str:
        return f"{t}  ({loc} | {prio} | {age})"

    full = assemble(title)
    if len(full) <= max_width:
        return full

    for new_len in range(len(title) - 1, 0, -1):
        candidate = assemble(_ellipsize(title, new_len))
        if len(candidate) <= max_width:
            return candidate
    return _ellipsize(assemble(_ellipsize(title, 1)), max_width)


def _poke_pass(
    meta: ProjectMeta,
    items: list[dict],
    from_statuses: set[str],
    to_status: str,
    forced_ids: Optional[list[str]],
    yes: bool,
) -> int:
    bucket = [
        it for it in items
        if (it["fields"].get("Status") or NO_STATUS) in from_statuses
    ]
    if not bucket:
        print(f"  (nothing to move from {' / '.join(sorted(from_statuses))})")
        return 0

    priority_order = meta.field("Priority").option_names()

    def key(it: dict):
        cat = it["fields"].get("Category") or "~"
        proj = it["fields"].get("Project") or "~"
        prio = it["fields"].get("Priority") or "~"
        return (cat, proj, _priority_rank(prio, priority_order), it.get("created_at") or "")

    bucket.sort(key=key)

    if forced_ids is not None:
        chosen = [it for it in bucket if it["item_id"] in set(forced_ids)]
    else:
        max_width = _terminal_columns() - 16
        choices = []
        current_group: Optional[tuple[str, Optional[str]]] = None
        header_idx = 0
        for it in bucket:
            cat = it["fields"].get("Category") or "-"
            proj = it["fields"].get("Project")
            group = (cat, proj)
            if group != current_group:
                label = f"── {cat}{f' / {proj}' if proj else ''} ──"
                # dialog has no non-selectable rows; sentinel tag is filtered
                # out of the picks below.
                choices.append((f"__hdr_{header_idx}", label, False))
                header_idx += 1
                current_group = group
            prio = it["fields"].get("Priority") or "-"
            repo = it.get("repo")
            if repo and it.get("number"):
                # Strip the org — it's always nod-ai/iree-org/llvm/etc., and
                # the repo name alone is unique within this project.
                loc = f"{repo.split('/', 1)[-1]}#{it['number']}"
            else:
                loc = "(draft)"
            age = _days_old(it.get("created_at"))
            desc = _fit_poke_desc(it["title"], loc, prio, age, max_width)
            choices.append((it["item_id"], desc, False))
        picks = dialog_checklist(
            f"Move to {to_status}",
            f"Select items to move {' / '.join(sorted(from_statuses))} → {to_status}",
            choices,
            no_tags=True,
        )
        if picks is None:
            print("  (cancelled)")
            return 0
        picked = {p for p in picks if not p.startswith("__hdr_")}
        chosen = [it for it in bucket if it["item_id"] in picked]

    if not chosen:
        print("  (nothing selected)")
        return 0

    if not yes and forced_ids is None:
        names = "\n".join(
            f"  • {it['repo'] or 'draft'}#{it.get('number', '')} — {it['title']}"
            for it in chosen
        )
        if not dialog_yesno(
            f"Move {len(chosen)} → {to_status}",
            f"Move these to {to_status}?\n\n{names}",
        ):
            print("  (cancelled)")
            return 0

    field_meta = meta.field("Status")
    for it in chosen:
        set_single_select(meta.id, it["item_id"], field_meta, to_status)
    return len(chosen)


def cmd_list_field(args, meta: ProjectMeta) -> int:
    f = meta.field(args._field_name)
    for name in f.option_names():
        print(name)
    return 0


def cmd_poke(args, meta: ProjectMeta) -> int:
    user = args.user
    all_items = fetch_project_items()
    mine = [
        it for it in all_items
        if it.get("author") == user or user in (it.get("assignees") or [])
    ]
    if not mine:
        print(f"No items authored or assigned to {user}.")
        return 0

    forced = None
    if args.items:
        forced = [s.strip() for s in args.items.split(",") if s.strip()]

    moved_a = 0
    moved_b = 0
    if not args.no_todo:
        print(f"\n# Pass A: Todo / no-status → In Progress")
        moved_a = _poke_pass(meta, mine, {"Todo", NO_STATUS}, "In Progress", forced, args.yes)
    if not args.no_in_progress:
        print(f"\n# Pass B: In Progress → Done")
        # Re-fetch so newly-moved items in pass A appear in pass B if user wants
        # to push them straight through (rare, but matches the obvious mental model).
        if not args.no_todo and moved_a:
            all_items = fetch_project_items()
            mine = [
                it for it in all_items
                if it.get("author") == user or user in (it.get("assignees") or [])
            ]
        moved_b = _poke_pass(meta, mine, {"In Progress"}, "Done", forced, args.yes)

    print(f"\nMoved {moved_a} to In Progress, {moved_b} to Done.")
    return 0


# ── Argparse ─────────────────────────────────────────────────────────────────


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="iree-tracker",
        description="CLI for the nod-ai Codegen Tracker (Projects v2 #40).",
    )
    p.add_argument("--refresh-cache", action="store_true",
                   help="Re-fetch project field/option metadata before running")
    sub = p.add_subparsers(dest="command", required=True)

    # create
    sp = sub.add_parser("create", help="Create a new tracker issue")
    sp.add_argument("title", nargs="?", help="Seed title (also written as # title in the editor)")
    sp.add_argument("-R", "--repo",
                    help="iree | draft | owner/name (default: prompt)")
    sp.add_argument("-b", "--body-file", help="Use this file as the issue body (skips $EDITOR)")
    sp.add_argument("--body", help="Inline issue body (skips $EDITOR)")
    sp.add_argument("--no-editor", action="store_true",
                    help="Don't open $EDITOR; requires --title")
    sp.add_argument("-l", "--label", action="append",
                    help="Label name (repeatable). Empty string means 'no labels, skip prompt'.")
    sp.add_argument("-c", "--category", help='Category option name ("" or "na" to leave unset)')
    sp.add_argument("-p", "--priority", help='Priority option name ("" or "na" to leave unset)')
    sp.add_argument("--project-field", help='Project option name ("" or "na" to leave unset)')
    sp.add_argument("-a", "--assignee", help="me | none | <handle>")
    sp.add_argument("-s", "--status", help='Status option name (default: Todo, "na" to leave unset)')
    sp.add_argument("-y", "--yes", action="store_true", help="Skip the final confirm dialog")
    sp.set_defaults(func=cmd_create)

    # import
    sp = sub.add_parser("import", help="Add an existing issue/PR to the tracker")
    sp.add_argument("url", help="https://github.com/<owner>/<repo>/issues/<n>")
    sp.add_argument("-c", "--category", help='("" or "na" to leave unset)')
    sp.add_argument("-p", "--priority", help='("" or "na" to leave unset)')
    sp.add_argument("--project-field", help='("" or "na" to leave unset)')
    sp.add_argument("-s", "--status", help='default: Todo ("na" to leave unset)')
    sp.add_argument("--takeover", action=argparse.BooleanOptionalAction, default=None,
                    help=f"Assign the issue to {DEFAULT_USER} (default: ask)")
    sp.add_argument("-y", "--yes", action="store_true")
    sp.set_defaults(func=cmd_import)

    # created / assigned
    for name, fn, helptext in [
        ("created", cmd_created, "List items authored by USER (default krzysz00)"),
        ("assigned", cmd_assigned, "List items assigned to USER (default krzysz00)"),
    ]:
        sp = sub.add_parser(name, help=helptext)
        sp.add_argument("user", nargs="?", default=DEFAULT_USER)
        sp.add_argument("-u", "--user", dest="user_flag",
                        help="Alternate spelling of the positional USER")
        sp.add_argument("-s", "--status", action="append",
                        help="Filter to this status (repeatable)")
        sp.add_argument("--all-status", action="store_true",
                        help="Include Done in the output (default: only active items)")
        sp.add_argument("--format", choices=["text", "json"], default="text")
        sp.set_defaults(func=fn)

    # poke
    sp = sub.add_parser("poke", help="Walk through Todo→InProgress, then InProgress→Done")
    sp.add_argument("-u", "--user", default=DEFAULT_USER)
    sp.add_argument("--no-todo", action="store_true", help="Skip pass A")
    sp.add_argument("--no-in-progress", action="store_true", help="Skip pass B")
    sp.add_argument("--items", help="Comma-separated project item IDs to move (no TUI)")
    sp.add_argument("-y", "--yes", action="store_true")
    sp.set_defaults(func=cmd_poke)

    # list-categories / list-projects
    for name, field_name, helptext in [
        ("list-categories", "Category", "Print every Category option, one per line"),
        ("list-projects", "Project", "Print every Project option, one per line"),
    ]:
        sp = sub.add_parser(name, help=helptext)
        sp.set_defaults(func=cmd_list_field, _field_name=field_name)

    return p


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    # Reconcile -u/--user with positional USER for created/assigned.
    if hasattr(args, "user_flag") and args.user_flag:
        args.user = args.user_flag

    try:
        meta = load_project_meta(refresh=args.refresh_cache)
    except GhError as e:
        sys.exit(str(e))

    try:
        return args.func(args, meta) or 0
    except (GhError, ValueError) as e:
        sys.exit(str(e))
    except KeyboardInterrupt:
        sys.exit("\nAborted.")


if __name__ == "__main__":
    sys.exit(main())
